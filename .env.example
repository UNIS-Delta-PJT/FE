# 백엔드 API 주소 (trycloudflare 터널 주소가 바뀌면 여기만 수정)
VITE_API_BASE_URL=https://singing-moisture-voters-don.trycloudflare.com

# 카카오 로그인 — developers.kakao.com 앱의 REST API 키
# 카카오 콘솔에 Redirect URI(각 환경별)와 웹 도메인이 등록돼 있어야 함
VITE_KAKAO_REST_API_KEY=
# 미설정 시 {현재 origin}/kakao/login 사용
VITE_KAKAO_REDIRECT_URI=
